{
  "name": "cryptoguard",
  "version": "1.0.0",
  "description": "Real-time cryptocurrency scam interception platform.",
  "scripts": {
    "start": "./start.sh",
    "dev:backend": "cd backend && ./venv/bin/python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:frontend": "cd frontend && npm run dev -- --host 127.0.0.1 --port 5173",
    "build": "cd frontend && npm run build",
    "vercel-build": "cd frontend && npm install && npm run build",
    "health": "curl -fsS http://127.0.0.1:8000/health",
    "deploy:vercel": "vercel --prod"
  }
}
